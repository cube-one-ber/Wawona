// Skip shared app metadata (https://skip.dev), same role as skipapp-bookings-fuse/Skip.env:
// values feed Darwin xcconfig / Android Gradle (via skip-build-plugin or manual sync) and
// app metadata (Info.plist, AndroidManifest placeholders where used).
//
// PRODUCT_NAME should match the primary Swift module that owns the fused UI entry point
// (here the app shell is Wawona; Skip still emits the UI package as `wawona.ui` from WawonaUI).

PRODUCT_NAME = Wawona
PRODUCT_BUNDLE_IDENTIFIER = com.aspauldingcode.wawona
MARKETING_VERSION = 0.2.3
CURRENT_PROJECT_VERSION = 1
ANDROID_PACKAGE_NAME = com.aspauldingcode.wawona
